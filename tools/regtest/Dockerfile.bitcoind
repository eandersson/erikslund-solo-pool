# Regtest bitcoind for the erikslund-pool test harness.
# Downloads the official Bitcoin Core release binary and verifies it against
# the published SHA256SUMS before use.
FROM debian:trixie-slim AS fetch
ARG BTC_VERSION=31.0
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates wget && rm -rf /var/lib/apt/lists/*
WORKDIR /tmp
RUN set -eu; \
    base="https://bitcoincore.org/bin/bitcoin-core-${BTC_VERSION}"; \
    tarball="bitcoin-${BTC_VERSION}-x86_64-linux-gnu.tar.gz"; \
    wget -q "${base}/${tarball}"; \
    wget -q "${base}/SHA256SUMS"; \
    grep " ${tarball}\$" SHA256SUMS | sha256sum -c -; \
    tar -xzf "${tarball}"; \
    install -m0755 "bitcoin-${BTC_VERSION}/bin/bitcoind" /usr/local/bin/bitcoind; \
    install -m0755 "bitcoin-${BTC_VERSION}/bin/bitcoin-cli" /usr/local/bin/bitcoin-cli

FROM debian:trixie-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        libstdc++6 libgcc-s1 && rm -rf /var/lib/apt/lists/*
COPY --from=fetch /usr/local/bin/bitcoind /usr/local/bin/bitcoind
COPY --from=fetch /usr/local/bin/bitcoin-cli /usr/local/bin/bitcoin-cli
RUN useradd -m -d /data bitcoin
USER bitcoin
# 18443 = regtest RPC, 28332 = zmq hashblock
EXPOSE 18443 28332
ENTRYPOINT ["bitcoind"]
CMD ["-conf=/etc/bitcoin/bitcoin.conf", "-datadir=/data"]
